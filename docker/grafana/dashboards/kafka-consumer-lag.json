      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }
      },
      "targets": [ { "expr": "count(sum by (consumergroup) (kafka_consumergroup_lag) > 100)", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Brokers up",
      "id": 4,
