      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineInterpolation": "stepAfter", "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } },
      "targets": [
        { "expr": "kafka_consumergroup_lag{consumergroup=\"$group\"}", "legendFormat": "{{topic}} p{{partition}}", "refId": "A" }
      ]
