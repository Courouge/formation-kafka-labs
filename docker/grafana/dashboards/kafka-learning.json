        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Bytes entrants par broker",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance) (rate(kafka_server_brokertopicmetrics_bytesinpersec_total[1m]))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "ISR shrink / expand pendant les incidents",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (instance) (rate(kafka_server_replicamanager_isrshrinkspersec_total[5m]))",
          "legendFormat": "shrinks {{instance}}",
          "refId": "A"
        },
        {
          "expr": "sum by (instance) (rate(kafka_server_replicamanager_isrexpandspersec_total[5m]))",
          "legendFormat": "expands {{instance}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka Connect records / sec",
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (connector) (rate(kafka_connect_source_task_metrics_source_record_write_total[1m]))",
          "legendFormat": "source {{connector}}",
          "refId": "A"
        },
        {
          "expr": "sum by (connector) (rate(kafka_connect_sink_task_metrics_sink_record_read_total[1m]))",
          "legendFormat": "sink {{connector}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "text",
      "title": "Ce qu'il faut observer par lab",
      "id": 10,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "options": {
        "mode": "markdown",
        "content": "- L1 : les 3 brokers sont UP, under-replicated partitions = 0.\\n- L2 / L5 : messages entrants augmente pendant les producers.\\n- L4 / M7 : Kafka Connect records/sec bouge quand Debezium publie.\\n- L8 : stopper un broker doit faire baisser Brokers up et peut provoquer ISR shrink / URP temporaire.\\n\\nComplétez les screenshots demandés dans `modules/B1-M06/OBSERVABILITE_LABS.md`."
      }
    }
  ],
